{
  "name": "ga4-monitor-desktop",
  "version": "1.0.0",
  "description": "GA4 Monitoring Desktop Application - Automated testing and reporting for Google Analytics 4",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_NO_WARNINGS=1 concurrently -k \"cross-env BROWSER=none NODE_NO_WARNINGS=1 npm run dev:renderer\" \"wait-on http://localhost:3000 && cross-env NODE_NO_WARNINGS=1 npm run dev:main\"",
    "dev:main": "cross-env NODE_NO_WARNINGS=1 NODE_ENV=development electron .",
    "dev:renderer": "cross-env NODE_NO_WARNINGS=1 vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "lint": "eslint src --ext .ts,.tsx",
    "postinstall": "electron-rebuild",
    "rebuild": "electron-rebuild",
    "start": "cross-env NODE_NO_WARNINGS=1 concurrently -k \"cross-env BROWSER=none NODE_NO_WARNINGS=1 npm run dev:renderer\" \"wait-on http://localhost:3000 && cross-env NODE_NO_WARNINGS=1 npm run dev:main\"",
    "stop": "powershell -Command \"Get-Process | Where-Object {$_.ProcessName -like '*electron*' -or $_.MainWindowTitle -like '*GA4*'} | Stop-Process -Force -ErrorAction SilentlyContinue\"",
    "restart": "npm run stop && timeout /t 2 /nobreak > nul && npm run start"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@tanstack/react-query": "^5.14.0",
    "@types/cheerio": "^0.22.35",
    "@types/react": "^18.2.0",
    "axios": "^1.6.0",
    "cheerio": "^1.1.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.0",
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0",
    "exceljs": "^4.4.0",
    "google-auth-library": "^9.4.0",
    "googleapis": "^128.0.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "sql.js": "^1.10.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}